<!DOCTYPE html>
<html lang="ar">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gemini GPT - Clone</title>
    <style>
        /* ===== RESET ===== */
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, sans-serif;
            background: #343541;
            color: #ececf1;
            height: 100vh;
            display: flex;
            overflow: hidden;
        }

        /* ===== SIDEBAR ===== */
        #sidebar {
            width: 260px;
            background: #202123;
            padding: 14px;
            display: flex;
            flex-direction: column;
            gap: 10px;
            border-right: 1px solid #4a4b5a;
            overflow-y: auto;
            flex-shrink: 0;
        }
        #sidebar::-webkit-scrollbar { width: 6px; }
        #sidebar::-webkit-scrollbar-thumb { background: #565869; border-radius: 10px; }

        #new-chat-btn {
            background: #0b93f6;
            border: none;
            color: white;
            padding: 14px;
            border-radius: 8px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            width: 100%;
            font-size: 15px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }
        #new-chat-btn:hover { background: #1a7fd1; transform: scale(1.02); }
        #new-chat-btn:active { transform: scale(0.98); }

        #conv-list {
            display: flex;
            flex-direction: column;
            gap: 4px;
            flex: 1;
            overflow-y: auto;
        }
        .conv-item {
            padding: 10px 12px;
            background: #2d2d3a;
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.15s;
            font-size: 14px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-left: 3px solid transparent;
        }
        .conv-item:hover { background: #3a3b4a; }
        .conv-item.active {
            background: #3a3b4a;
            border-left-color: #0b93f6;
        }
        .conv-item span { 
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            flex: 1;
        }
        .delete-conv {
            background: transparent;
            border: none;
            color: #8e8ea0;
            cursor: pointer;
            font-size: 16px;
            padding: 0 5px;
            transition: 0.2s;
            flex-shrink: 0;
        }
        .delete-conv:hover { color: #ff6b6b; }

        /* ===== MAIN AREA ===== */
        #main-area {
            flex: 1;
            display: flex;
            flex-direction: column;
            height: 100vh;
            background: #343541;
        }

        /* ===== CHAT CONTAINER ===== */
        #chat-container {
            flex: 1;
            overflow-y: auto;
            padding: 20px 10%;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }
        #chat-container::-webkit-scrollbar { width: 8px; }
        #chat-container::-webkit-scrollbar-thumb { background: #565869; border-radius: 10px; }

        .message {
            padding: 14px 20px;
            border-radius: 14px;
            max-width: 80%;
            word-wrap: break-word;
            line-height: 1.7;
            animation: fadeIn 0.25s ease;
            position: relative;
        }
        .user {
            align-self: flex-end;
            background: #0b93f6;
            color: white;
        }
        .bot {
            align-self: flex-start;
            background: #444654;
            color: #ececf1;
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(12px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .msg-actions {
            margin-top: 8px;
            display: flex;
            gap: 14px;
            font-size: 13px;
            opacity: 0.6;
        }
        .msg-actions span {
            cursor: pointer;
            transition: 0.2s;
            user-select: none;
        }
        .msg-actions span:hover { opacity: 1; color: #fff; }

        #loading {
            display: none;
            align-self: flex-start;
            background: #444654;
            padding: 12px 20px;
            border-radius: 14px;
            color: #aaa;
            animation: pulse 1.5s ease-in-out infinite;
        }
        @keyframes pulse {
            0%, 100% { opacity: 0.6; }
            50% { opacity: 1; }
        }

        .error-msg {
            color: #ff6b6b;
            background: #3d1f1f;
            padding: 12px 18px;
            border-radius: 10px;
            text-align: center;
            border: 1px solid #ff6b6b33;
        }

        /* ===== INPUT AREA ===== */
        #input-area {
            background: #40414f;
            padding: 16px 10%;
            display: flex;
            gap: 12px;
            border-top: 1px solid #565869;
            flex-shrink: 0;
        }
        #user-input {
            flex: 1;
            padding: 14px 22px;
            border: none;
            border-radius: 30px;
            background: #2d2d3a;
            color: white;
            font-size: 16px;
            outline: none;
            transition: 0.2s;
        }
        #user-input:focus { background: #3a3b4a; }
        #user-input::placeholder { color: #8e8ea0; }

        #send-btn {
            background: #0b93f6;
            color: white;
            border: none;
            border-radius: 30px;
            padding: 0 32px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.2s;
            font-size: 16px;
            white-space: nowrap;
        }
        #send-btn:hover { background: #1a7fd1; transform: scale(1.03); }
        #send-btn:active { transform: scale(0.97); }

        /* ===== RESPONSIVE ===== */
        @media (max-width: 768px) {
            #sidebar { width: 200px; padding: 10px; }
            #chat-container { padding: 15px 5%; }
            #input-area { padding: 12px 5%; flex-wrap: wrap; }
            .message { max-width: 90%; }
            #send-btn { padding: 0 20px; font-size: 14px; }
        }
        @media (max-width: 480px) {
            #sidebar { width: 0; padding: 0; overflow: hidden; border: none; }
            #sidebar.open { width: 200px; padding: 10px; overflow-y: auto; }
        }
    </style>
</head>
<body>

    <!-- ===== SIDEBAR ===== -->
    <div id="sidebar">
        <button id="new-chat-btn">➕ محادثة جديدة</button>
        <div id="conv-list"></div>
    </div>

    <!-- ===== MAIN ===== -->
    <div id="main-area">
        <div id="chat-container">
            <div class="message bot">مرحباً! أنا نسخة متكاملة من ChatGPT تعمل بتقنية Gemini. كيف يمكنني مساعدتك اليوم؟</div>
            <div id="loading">⏳ جاري التفكير...</div>
        </div>
        <div id="input-area">
            <input type="text" id="user-input" placeholder="اكتب رسالتك..." autofocus>
            <button id="send-btn">إرسال</button>
        </div>
    </div>

    <script>
        // ===== المتغيرات العامة =====
        let currentConvId = null;
        let lastBotElement = null;
        let lastUserMessage = '';

        const chatContainer = document.getElementById('chat-container');
        const userInput = document.getElementById('user-input');
        const sendBtn = document.getElementById('send-btn');
        const loadingDiv = document.getElementById('loading');
        const convList = document.getElementById('conv-list');
        const newChatBtn = document.getElementById('new-chat-btn');

        // ===== دوال مساعدة =====
        function addMessage(text, sender, showActions = false) {
            const msgDiv = document.createElement('div');
            msgDiv.className = `message ${sender}`;
            
            const textSpan = document.createElement('span');
            textSpan.textContent = text;
            msgDiv.appendChild(textSpan);

            if (sender === 'bot' && showActions) {
                const actionsDiv = document.createElement('div');
                actionsDiv.className = 'msg-actions';
                actionsDiv.innerHTML = `
                    <span onclick="copyMessage(this)">📋 نسخ</span>
                    <span onclick="regenerateMessage()">🔄 إعادة توليد</span>
                `;
                msgDiv.appendChild(actionsDiv);
                lastBotElement = msgDiv;
            }

            chatContainer.insertBefore(msgDiv, loadingDiv);
            chatContainer.scrollTop = chatContainer.scrollHeight;
            return msgDiv;
        }

        function addError(text) {
            const errDiv = document.createElement('div');
            errDiv.className = 'message bot error-msg';
            errDiv.textContent = '⚠️ ' + text;
            chatContainer.insertBefore(errDiv, loadingDiv);
            chatContainer.scrollTop = chatContainer.scrollHeight;
        }

        function copyMessage(el) {
            const msgText = el.closest('.message').querySelector('span').textContent;
            navigator.clipboard.writeText(msgText).then(() => {
                el.textContent = '✅ تم النسخ';
                setTimeout(() => el.textContent = '📋 نسخ', 1500);
            }).catch(() => {
                // طريقة بديلة للنسخ
                const textarea = document.createElement('textarea');
                textarea.value = msgText;
                document.body.appendChild(textarea);
                textarea.select();
                document.execCommand('copy');
                textarea.remove();
                el.textContent = '✅ تم النسخ';
                setTimeout(() => el.textContent = '📋 نسخ', 1500);
            });
        }

        async function regenerateMessage() {
            if (!lastBotElement || !lastUserMessage) return;
            
            // حذف آخر رسالة بوت
            lastBotElement.remove();
            lastBotElement = null;
            
            // إعادة إرسال آخر رسالة مستخدم
            await sendMessageToServer(lastUserMessage, true);
        }

        // ===== إرسال الرسالة للخادم =====
        async function sendMessageToServer(message, isRegenerate = false) {
            loadingDiv.style.display = 'block';
            
            try {
                const response = await fetch('/chat', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ message: message })
                });
                
                const data = await response.json();
                loadingDiv.style.display = 'none';

                if (data.error) {
                    addError(data.error);
                } else {
                    addMessage(data.reply, 'bot', true);
                    await loadConversations();
                }
            } catch (err) {
                loadingDiv.style.display = 'none';
                addError('فشل الاتصال بالخادم. تأكد من تشغيل السيرفر.');
            }
        }

        // ===== إرسال رسالة من الواجهة =====
        async function sendMessage() {
            const message = userInput.value.trim();
            if (!message) return;

            // تخزين آخر رسالة مستخدم لإعادة التوليد
            lastUserMessage = message;
            
            addMessage(message, 'user');
            userInput.value = '';
            await sendMessageToServer(message);
        }

        // ===== تحميل تاريخ المحادثة الحالية =====
        async function loadCurrentHistory() {
            try {
                const resp = await fetch('/get_history');
                const data = await resp.json();
                
                // مسح جميع الرسائل (نحتفظ بالـ loading)
                document.querySelectorAll('.message').forEach(el => el.remove());
                
                if (data.history && data.history.length > 0) {
                    data.history.forEach((msg, index) => {
                        const isLast = (index === data.history.length - 1);
                        addMessage(msg.text, msg.role, (msg.role === 'bot' && isLast));
                    });
                } else {
                    addMessage('مرحباً! محادثة جديدة. ابدأ بكتابة رسالتك.', 'bot');
                }
            } catch (err) {
                addError('فشل تحميل التاريخ');
            }
        }

        // ===== تحميل قائمة المحادثات =====
        async function loadConversations() {
            try {
                const resp = await fetch('/list_conversations');
                const data = await resp.json();
                
                convList.innerHTML = '';
                data.conversations.forEach(conv => {
                    const div = document.createElement('div');
                    div.className = 'conv-item';
                    if (conv.id === currentConvId) div.classList.add('active');
                    
                    const span = document.createElement('span');
                    span.textContent = conv.preview;
                    
                    const delBtn = document.createElement('button');
                    delBtn.className = 'delete-conv';
                    delBtn.textContent = '✕';
                    delBtn.dataset.id = conv.id;
                    delBtn.addEventListener('click', (e) => {
                        e.stopPropagation();
                        deleteConversation(conv.id);
                    });
                    
                    div.appendChild(span);
                    div.appendChild(delBtn);
                    
                    div.addEventListener('click', () => {
                        if (!div.classList.contains('active')) {
                            switchConversation(conv.id);
                        }
                    });
                    
                    convList.appendChild(div);
                });
            } catch (err) {
                console.error('فشل تحميل قائمة المحادثات', err);
            }
        }

        // ===== التبديل بين المحادثات =====
        async function switchConversation(convId) {
            try {
                const resp = await fetch('/switch_chat', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ conv_id: convId })
                });
                const data = await resp.json();
                
                if (data.history) {
                    currentConvId = convId;
                    document.querySelectorAll('.message').forEach(el => el.remove());
                    
                    if (data.history.length > 0) {
                        data.history.forEach((msg, index) => {
                            const isLast = (index === data.history.length - 1);
                            addMessage(msg.text, msg.role, (msg.role === 'bot' && isLast));
                        });
                    } else {
                        addMessage('محادثة فارغة. ابدأ بالكتابة.', 'bot');
                    }
                    
                    await loadConversations();
                }
            } catch (err) {
                addError('فشل التبديل بين المحادثات');
            }
        }

        // ===== حذف محادثة =====
        async function deleteConversation(convId) {
            if (!confirm('هل تريد حذف هذه المحادثة؟')) return;
            
            try {
                const resp = await fetch('/delete_chat', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ conv_id: convId })
                });
                const data = await resp.json();
                
                if (data.status === 'deleted') {
                    await loadConversations();
                    await loadCurrentHistory();
                    
                    // تحديث currentConvId من العنصر النشط
                    const active = document.querySelector('.conv-item.active');
                    if (active) {
                        const delBtn = active.querySelector('.delete-conv');
                        if (delBtn) currentConvId = delBtn.dataset.id;
                    }
                }
            } catch (err) {
                addError('فشل حذف المحادثة');
            }
        }

        // ===== إنشاء محادثة جديدة =====
        async function newConversation() {
            try {
                const resp = await fetch('/new_chat', { method: 'POST' });
                const data = await resp.json();
                currentConvId = data.conv_id;
                
                document.querySelectorAll('.message').forEach(el => el.remove());
                addMessage('محادثة جديدة. كيف يمكنني مساعدتك؟', 'bot');
                await loadConversations();
            } catch (err) {
                addError('فشل إنشاء محادثة جديدة');
            }
        }

        // ===== أحداث =====
        sendBtn.addEventListener('click', sendMessage);
        userInput.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                sendMessage();
            }
        });
        newChatBtn.addEventListener('click', newConversation);

        // ===== التهيئة عند تحميل الصفحة =====
        (async function init() {
            try {
                // تحميل المحادثة الحالية
                const resp = await fetch('/get_history');
                const data = await resp.json();
                currentConvId = data.conv_id;
                
                if (data.history && data.history.length > 0) {
                    document.querySelectorAll('.message').forEach(el => el.remove());
                    data.history.forEach((msg, index) => {
                        const isLast = (index === data.history.length - 1);
                        addMessage(msg.text, msg.role, (msg.role === 'bot' && isLast));
                    });
                }
                
                await loadConversations();
            } catch (err) {
                addError('فشل تحميل البيانات الأولية');
            }
        })();

        // تصحيح: تحديث currentConvId عند النقر على محادثة
        // تمت معالجته داخل switchConversation
    </script>
</body>
</html>
